# ── Anthropic ──────────────────────────────────────────────────────────────────
# Server-side only — used by api/recommendation.ts (Vercel serverless function).
# NEVER use VITE_ prefix for this key; VITE_* vars are bundled into client JS.
ANTHROPIC_API_KEY=

# ── Supabase ───────────────────────────────────────────────────────────────────
# Public anon key — safe to expose in the browser (row-level security enforced).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Local dev only ─────────────────────────────────────────────────────────────
# Used in dev so the Vite proxy to api.anthropic.com can attach the key.
# Not needed in production (serverless function uses ANTHROPIC_API_KEY above).
VITE_ANTHROPIC_API_KEY=
